{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true
  },
  "include": ["./**/*.ts", "./**/*.svelte"],
  "exclude": ["node_modules"]
}
